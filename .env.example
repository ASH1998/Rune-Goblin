# Hugging Face access token (read scope is enough to download; write to push adapters)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GGUF / multimodal serving model (llama.cpp path; NOT used for LoRA fine-tuning)
MODEL=openbmb/MiniCPM-o-4_5-gguf

# Optional overrides used by inference.py
# RG_BASE_MODEL=models/MiniCPM5-1B-SFT
# RG_ADAPTER=models/rune-goblin-lora

# Optional overrides used by app/vision_app.py and rune_goblin.vision_inference
# Use the local fine-tuned GGUF by default once downloaded.
RG_VISION_MODEL=models/goblinV1-gguf/gguf/rune-goblin-v46-Q4_K_M.gguf
RG_VISION_MMPROJ=models/goblinV1-gguf/gguf/rune-goblin-v46-mmproj-f16.gguf

# Story dialogue backend (NPC chat). Active path = hosted OpenAI-compatible API.
RG_USE_DIALOGUE_API=1
RG_DIALOGUE_API_URL=http://your-host:8004/v1/chat/completions
RG_DIALOGUE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RG_DIALOGUE_API_MODEL=MiniCPM-V-4.6-Thinking
# RG_DIALOGUE_MAX_TOKENS=1024   # thinking model: must cover CoT + JSON answer
# RG_DIALOGUE_API_TIMEOUT=30
