{
  "assistant_json_schema": {
    "type": "object",
    "required": [
      "spell_name",
      "spell_type",
      "flavor",
      "effect",
      "side_effect",
      "enemy_hp_delta",
      "player_hp_delta",
      "status_effects",
      "chaos"
    ],
    "properties": {
      "spell_name": {
        "type": "string"
      },
      "spell_type": {
        "type": "string"
      },
      "flavor": {
        "type": "string"
      },
      "effect": {
        "type": "string"
      },
      "side_effect": {
        "type": "string"
      },
      "enemy_hp_delta": {
        "type": "integer",
        "minimum": -4,
        "maximum": 0
      },
      "player_hp_delta": {
        "type": "integer",
        "minimum": -2,
        "maximum": 3
      },
      "status_effects": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "chaos": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10
      }
    }
  },
  "dataset_format": {
    "id": "string",
    "category": "one of basic_spells, combo_spells, cursed_spells, enemy_specific, invalid_edge_cases",
    "rune_count": "integer",
    "runes": "list[string]",
    "enemy": "string",
    "weakness": "string",
    "resistance": "string",
    "messages": "ChatML-style list of system/user/assistant messages"
  },
  "runes": [
    "spiral",
    "jagged_line",
    "closed_circle",
    "three_dots",
    "wave",
    "eye",
    "bone",
    "leaf",
    "flame",
    "key",
    "mirror",
    "bell",
    "tooth",
    "thread",
    "coin",
    "broken_mark"
  ],
  "categories": {
    "basic_spells": 2000,
    "combo_spells": 1200,
    "cursed_spells": 700,
    "enemy_specific": 700,
    "invalid_edge_cases": 400
  },
  "combination_rules": {
    "eye+spiral": "prophecy / see future move",
    "closed_circle+flame": "burning shield",
    "bone+three_dots": "skeleton swarm",
    "jagged_line+mirror": "reflect damage",
    "key+wave": "unlock emotional door",
    "thread+tooth": "bind and bite",
    "bell+coin": "summon a merchant spirit",
    "bone+leaf": "healing with decay risk",
    "eye+mirror": "reveal enemy weakness"
  }
}